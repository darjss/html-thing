{
  "name": "html-thing",
  "version": "0.0.0",
  "description": "One-command HTML hosting on Cloudflare R2 → html.darjs.dev",
  "homepage": "https://github.com/darjss/html-thing#readme",
  "bugs": {
    "url": "https://github.com/darjss/html-thing/issues"
  },
  "license": "MIT",
  "author": "darjss",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darjss/html-thing.git"
  },
  "bin": {
    "html-thing": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.9.0"
}
